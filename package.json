{
  "name": "rendersend",
  "version": "0.0.1",
  "private": true,
  "description": "Zero-access encrypted hosting for HTML artifacts",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "node --experimental-strip-types scripts/dev.mjs",
    "dev:api": "pnpm --filter @rendersend/api dev",
    "dev:viewer": "pnpm --filter @rendersend/viewer dev",
    "dev:mcp": "pnpm --filter @rendersend/mcp start:dev",
    "build": "node scripts/build.mjs",
    "release": "node scripts/release.mjs",
    "share": "pnpm --filter @rendersend/mcp share",
    "print-mcp-config": "node scripts/print-mcp-config.mjs",
    "test:store": "node --experimental-strip-types --test packages/api/test/store.test.mjs",
    "test:e2e": "node --experimental-strip-types scripts/test-e2e.mjs",
    "test": "pnpm test:store && pnpm test:e2e"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3", "@swc/core", "tsup"]
  }
}
