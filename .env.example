# ─── API server ──────────────────────────────────────────────────────────────

PORT=8787

# Allowed CORS origin for the viewer. Set to your deployed viewer URL in prod.
# CORS_ORIGIN=https://app.rendersend.com

# ─── Database (metadata) ─────────────────────────────────────────────────────

# RENDERSEND_DB=sqlite   (default — uses a local file, good for dev)
# RENDERSEND_DB=postgres (requires DATABASE_URL below)

# Path to the SQLite file (sqlite mode only)
# RENDERSEND_DB_PATH=./storage/rendersend.db

# PostgreSQL connection string (postgres mode — Supabase, Neon, etc.)
# Use the Transaction pooler URL (port 6543) for Supabase — omit the password from the URL.
# DATABASE_URL=postgresql://postgres.<project-ref>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Set password separately to avoid URL-encoding issues with special characters (@, #, %, etc.)
# DATABASE_PASSWORD=your-password-here

# ─── Blob storage ────────────────────────────────────────────────────────────

# BLOB_STORE=fs  (default — local filesystem, good for dev)
# BLOB_STORE=s3  (requires S3_BUCKET below)

# Local storage root (fs mode only)
# STORAGE_DIR=./storage

# S3 / R2 / MinIO settings (s3 mode only)
# S3_BUCKET=rendersend-blobs
# S3_REGION=us-east-1
# S3_PREFIX=blobs/

# Custom endpoint — set for Cloudflare R2 or MinIO; leave blank for AWS S3
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

RENDERSEND_DEBUG=false

# ─── Auth ────────────────────────────────────────────────────────────────────

# AUTH_MODE=none     (default — trust X-Owner-Email header, no login required)
# AUTH_MODE=supabase (require Google login via Supabase Auth)

# Required when AUTH_MODE=supabase.
# Found in Supabase dashboard → Project Settings → API → Project URL.
# SUPABASE_URL=https://<project-ref>.supabase.co

# ─── Viewer env (set in packages/viewer/.env.local) ──────────────────────────
# Vite only bundles vars prefixed with VITE_ — put these in packages/viewer/.env.local, not here.

# VITE_AUTH_MODE=none
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here   ← "publishable key" in Supabase dashboard → API Keys

# ─── Google OAuth (configured in Supabase, not here) ─────────────────────────
# Go to Supabase dashboard → Authentication → Providers → Google.
# Paste your Google OAuth Client ID and Secret there.
# Get them from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI to add in Google Console:
#   https://<project-ref>.supabase.co/auth/v1/callback